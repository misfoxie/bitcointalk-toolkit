{
  "manifest_version": 3,
  "name": "Bitcointalk All-in-One Toolkit",
  "version": "1.0.0",
  "description": "Complete toolkit for Bitcointalk users: BBCode studio, thread scraper, campaign tools, security helpers, dark mode, and more.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],

  "host_permissions": [
    "https://bitcointalk.org/*",
    "https://raw.githubusercontent.com/*"
  ],

  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://bitcointalk.org/*"],
      "js": ["src/content/content-bundle.js"],
      "css": ["src/content/content.css"],
      "run_at": "document_end"
    }
  ],

  "icons": {
    "16":  "assets/icon16.png",
    "32":  "assets/icon32.png",
    "48":  "assets/icon48.png",
    "128": "assets/icon128.png"
  },

  "action": {
    "default_popup": "src/ui/popup.html",
    "default_title": "Bitcointalk Toolkit",
    "default_icon": {
      "16":  "assets/icon16.png",
      "32":  "assets/icon32.png",
      "48":  "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": [
        "src/ui/dashboard.html",
        "src/ui/options.html",
        "assets/*.png",
        "assets/*.svg"
      ],
      "matches": ["https://bitcointalk.org/*", "chrome-extension://*/*"]
    }
  ],

  "options_ui": {
    "page": "src/ui/options.html",
    "open_in_tab": true
  }
}
